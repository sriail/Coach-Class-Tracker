name = "class-management-system"
main = "worker.js"
compatibility_date = "2024-01-01"

# KV Namespace for storing class data
kv_namespaces = [
  { binding = "CLASS_DATA", id = "your-kv-namespace-id-here" }
]

# Environment variables for email service (optional - uncomment and configure)
# [vars]
# MAILGUN_DOMAIN = "your-domain.com"

# For production, use secrets instead of vars:
# Run: wrangler secret put MAILGUN_API_KEY
# Run: wrangler secret put MAILGUN_DOMAIN
